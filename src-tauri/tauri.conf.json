{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ansible Control Panel",
  "version": "0.1.0",
  "identifier": "com.ansible.control-panel",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:14300",
    "beforeBuildCommand": "",
    "frontendDist": "../static"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Ansible Control Panel",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {},
    "longDescription": "Red Hat–style Ansible web UI with database storage. Run playbooks, manage inventories, credentials, and job templates.",
    "shortDescription": "Ansible Control Panel",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "category": "DeveloperTool",
    "copyright": "",
    "externalBin": [],
    "publisher": null
  },
  "plugins": {}
}
